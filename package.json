{
  "name": "email-security-checker",
  "version": "2.6.2",
  "description": "Auditoría de seguridad de correo (SPF, DMARC, DKIM, BIMI, MTA-STS, TLS-RPT, DANE) y detección de proveedores vía DNS-over-HTTPS. Front-end estático, sin backend.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint js --max-warnings=0",
    "format": "prettier --write \"js/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^14.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.0.0",
    "vitest": "^2.0.0"
  }
}
